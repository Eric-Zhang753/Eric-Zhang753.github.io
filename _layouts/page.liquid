---
layout: default
---
{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

{% assign header_search_enabled = false %}
{% if page.header_bib_search or page.header_honors_search %}
  {% assign header_search_enabled = true %}
{% endif %}

<div class="post">
  <header class="post-header{% if header_search_enabled %} post-header-with-search{% endif %}">
    <div class="post-title-row">
      <h1 class="post-title">{{ page.title }}</h1>
      {% if header_search_enabled %}
        <div class="post-title-search">
          {% if page.header_bib_search %}
            {% include bib_search.liquid %}
          {% elsif page.header_honors_search %}
            {% include honors_search.liquid %}
          {% endif %}
        </div>
      {% endif %}
    </div>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    {{ content }}
  </article>

  {% if page.related_publications %}
    <h2>References</h2>
    <div class="publications">
      {% bibliography --cited_in_order %}
    </div>
  {% endif %}

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>
